<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>Tunis Score Pro</title>

<style>
body {
  margin: 0;
  font-family: "Segoe UI";
  direction: rtl;
  background: #0f172a;
  color: white;
}

/* HEADER */
header {
  background: linear-gradient(90deg, #e11d48, #7f1d1d);
  padding: 15px;
  text-align: center;
  font-size: 22px;
  font-weight: bold;
}

/* NAV */
nav {
  display: flex;
  justify-content: center;
  background: #020617;
  padding: 10px;
}

nav button {
  background: transparent;
  color: white;
  border: 1px solid #334155;
  margin: 5px;
  padding: 10px 15px;
  cursor: pointer;
  border-radius: 8px;
  transition: 0.3s;
}

nav button:hover {
  background: #e11d48;
}

/* SECTIONS */
section {
  display: none;
  padding: 20px;
}

.active {
  display: block;
}

/* MATCH CARD */
.match {
  background: #1e293b;
  padding: 15px;
  margin: 10px auto;
  width: 90%;
  border-radius: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: 0.3s;
}

.match:hover {
  transform: scale(1.02);
  background: #334155;
}

.team {
  font-weight: bold;
}

.score {
  font-size: 18px;
}

.live {
  color: #22c55e;
  font-size: 12px;
}

/* TABLE */
table {
  width: 95%;
  margin: auto;
  border-collapse: collapse;
  background: #1e293b;
  border-radius: 10px;
  overflow: hidden;
}

th {
  background: #e11d48;
  padding: 10px;
}

td {
  padding: 10px;
  border-bottom: 1px solid #334155;
}

tr:hover {
  background: #334155;
}

/* BADGE */
.badge {
  background: gold;
  color: black;
  padding: 3px 8px;
  border-radius: 5px;
  font-size: 12px;
}

/* ANIMATION */
.fade {
  animation: fadeIn 0.5s ease-in-out;
}

@keyframes fadeIn {
  from {opacity: 0;}
  to {opacity: 1;}
}
</style>

</head>
<body>

<header>
⚽ Tunis Score PRO 🇹🇳
</header>

<nav>
<button onclick="showPage('matches')">📺 مباريات</button>
<button onclick="showPage('teams')">🏟️ فرق</button>
<button onclick="showPage('scorers')">🏆 هدافين</button>
</nav>

<!-- MATCHES -->
<section id="matches" class="active fade">

<div class="match">
  <span class="team">الترجي</span>
  <span class="score">2 - 1 <span class="live">● LIVE</span></span>
  <span class="team">النجم الساحلي</span>
</div>

<div class="match">
  <span class="team">النادي الإفريقي</span>
  <span class="score">0 - 0</span>
  <span class="team">الصفاقسي</span>
</div>

</section>

<!-- TEAMS -->
<section id="teams" class="fade">
<table>
<tr><th>الفريق</th><th>المدينة</th></tr>
<tr><td>الترجي الرياضي</td><td>تونس</td></tr>
<tr><td>النجم الساحلي</td><td>سوسة</td></tr>
<tr><td>النادي الإفريقي</td><td>تونس</td></tr>
<tr><td>النادي الصفاقسي</td><td>صفاقس</td></tr>
</table>
</section>

<!-- SCORERS -->
<section id="scorers" class="fade">
<table id="scorersTable">
<tr>
<th>#</th>
<th>اللاعب</th>
<th>الفريق</th>
<th>الأهداف</th>
</tr>
</table>
</section>

<script>
function showPage(id) {
  document.querySelectorAll("section").forEach(sec => {
    sec.classList.remove("active");
  });

  document.getElementById(id).classList.add("active");
}

// DATA
const scorers = [
  { name: "حمزة الخضراوي", team: "الترجي", goals: 12 },
  { name: "يوسف العبدلي", team: "النجم", goals: 10 },
  { name: "علي الجلاصي", team: "الصفاقسي", goals: 8 }
];

const table = document.getElementById("scorersTable");

scorers.sort((a,b) => b.goals - a.goals);

scorers.forEach((p, index) => {
  let badge = index === 0 ? '<span class="badge">👑</span>' : '';

  const row = document.createElement("tr");
  row.innerHTML = `
    <td>${index + 1} ${badge}</td>
    <td>${p.name}</td>
    <td>${p.team}</td>
    <td>${p.goals}</td>
  `;
  table.appendChild(row);
});
</script>

</body>
</html>
